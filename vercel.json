{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://lol-tft-rank-production.up.railway.app/api/:path*"
    },
    {
      "source": "/cmd/:path*",
      "destination": "https://lol-tft-rank-production.up.railway.app/cmd/:path*"
    },
    {
      "source": "/song-request-queue/callback.html",
      "destination": "https://www.asrus.app/song-request-queue/callback.html"
    },
    {
      "source": "/song-request-queue/:path*",
      "destination": "https://www.asrus.app/song-request-queue/:path*"
    },
    {
      "source": "/rank-lol-tft/:path*",
      "destination": "https://lol-tft-rank.vercel.app/:path*"
    },
    {
      "source": "/portifolio",
      "destination": "https://portifolio-kappa-one-90.vercel.app/"
    },
    {
      "source": "/portifolio/:path*",
      "destination": "https://portifolio-kappa-one-90.vercel.app/:path*"
    },
    {
      "source": "/Portifolio",
      "destination": "https://portifolio-kappa-one-90.vercel.app/"
    },
    {
      "source": "/Portifolio/:path*",
      "destination": "https://portifolio-kappa-one-90.vercel.app/:path*"
    }
  ]
}
